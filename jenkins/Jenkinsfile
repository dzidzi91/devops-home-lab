pipeline {
    agent any

    environment {
        REGISTRY_IMAGE    = "192.168.56.10:5000/devops-platform-app"
        KUBECONFIG_FILE   = credentials('k8s-homelab-kubeconfig')
        K8S_NAMESPACE     = "devops"
        DEPLOYMENT_NAME   = "devops-platform"
        APP_HOST          = "192.168.56.12"
        APP_PORT          = "30080"
        GIT_BRANCH        = "main"
        HELM_CHART_PATH   = "k8s/devops-platform"
        HELM_VALUES_FILE  = "k8s/devops-platform/values.yaml"
        ARGO_APP_NAME     = "devops-platform"
        IMAGE_TAG         = "build-${BUILD_NUMBER}"
    }

    options {
        disableConcurrentBuilds()
        timestamps()
    }

    stages {
        stage('Checkout Source') {
            steps {
                checkout scm
            }
        }

        stage('Stop Self Trigger Loop') {
            steps {
                script {
                    def lastCommitMsg = sh(
                        script: "git log -1 --pretty=%B",
                        returnStdout: true
                    ).trim()

                    echo "Last commit message: ${lastCommitMsg}"

                    if (lastCommitMsg.startsWith('[jenkins-gitops]')) {
                        currentBuild.result = 'NOT_BUILT'
                        error('Stopping self-triggered Jenkins build.')
                    }
                }
            }
        }

        stage('Show Build Target') {
            steps {
                echo "Building image: ${REGISTRY_IMAGE}:${IMAGE_TAG}"
                echo "Helm chart path: ${HELM_CHART_PATH}"
                echo "Helm values file: ${HELM_VALUES_FILE}"
                echo "Argo app: ${ARGO_APP_NAME}"
            }
        }

        stage('Build Docker Image') {
            steps {
                sh '''
                    set -e
                    docker build -t ${REGISTRY_IMAGE}:${IMAGE_TAG} ./app
                '''
            }
        }

        stage('Push Docker Image') {
            steps {
                sh '''
                    set -e
                    docker push ${REGISTRY_IMAGE}:${IMAGE_TAG}
                '''
            }
        }

        stage('Check Kubernetes & Argo Access') {
            steps {
                sh '''
                    set -e
                    export KUBECONFIG=$KUBECONFIG_FILE

                    kubectl get nodes
                    kubectl get application ${ARGO_APP_NAME} -n argocd
                    kubectl get deployment ${DEPLOYMENT_NAME} -n ${K8S_NAMESPACE} || true
                '''
            }
        }

        stage('Update Helm Values') {
            steps {
                sh '''
                    set -e

                    test -f "${HELM_VALUES_FILE}"

                    echo "values.yaml before update:"
                    cat "${HELM_VALUES_FILE}"

                    sed -i 's|repository: .*|repository: '"${REGISTRY_IMAGE}"'|' "${HELM_VALUES_FILE}"
                    sed -i 's|tag: ".*"|tag: "'"${IMAGE_TAG}"'"|' "${HELM_VALUES_FILE}"

                    echo "values.yaml after update:"
                    cat "${HELM_VALUES_FILE}"
                '''
            }
        }

        stage('Validate Helm Chart') {
            steps {
                sh '''
                    set -e
                    helm template devops-platform ${HELM_CHART_PATH} > /tmp/devops-platform-rendered.yaml
                    test -s /tmp/devops-platform-rendered.yaml
                    echo "Helm chart rendered successfully."
                '''
            }
        }

        stage('Commit and Push to Git') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'GitHub-push-creds',
                    usernameVariable: 'GIT_USERNAME',
                    passwordVariable: 'GIT_TOKEN'
                )]) {
                    sh '''
                        set -e

                        git config user.name "Jenkins"
                        git config user.email "jenkins@local"

                        if git diff --quiet -- "${HELM_VALUES_FILE}"; then
                          echo "No changes detected in Helm values."
                          git rev-parse HEAD > .gitops_target_revision
                          exit 0
                        fi

                        git add "${HELM_VALUES_FILE}"
                        git commit -m "[jenkins-gitops] deploy ${DEPLOYMENT_NAME}:${IMAGE_TAG}"

                        NEW_REVISION=$(git rev-parse HEAD)
                        echo "$NEW_REVISION" > .gitops_target_revision
                        echo "New Git revision: $NEW_REVISION"

                        git remote set-url origin https://${GIT_USERNAME}:${GIT_TOKEN}@github.com/dzidzi91/devops-home-lab.git
                        git push origin HEAD:${GIT_BRANCH}
                    '''
                }
            }
        }

        stage('Force Argo Refresh') {
            steps {
                sh '''
                    set -e
                    export KUBECONFIG=$KUBECONFIG_FILE
                    kubectl annotate application ${ARGO_APP_NAME} -n argocd argocd.argoproj.io/refresh=hard --overwrite
                '''
            }
        }

        stage('Wait for Argo CD Sync') {
            steps {
                sh '''
                    set -e
                    export KUBECONFIG=$KUBECONFIG_FILE

                    TARGET_REVISION=$(cat .gitops_target_revision)
                    echo "Waiting for Argo CD to sync revision: $TARGET_REVISION"

                    for i in $(seq 1 60); do
                      SYNC_STATUS=$(kubectl get application ${ARGO_APP_NAME} -n argocd -o jsonpath='{.status.sync.status}' 2>/dev/null || true)
                      HEALTH_STATUS=$(kubectl get application ${ARGO_APP_NAME} -n argocd -o jsonpath='{.status.health.status}' 2>/dev/null || true)
                      LIVE_REVISION=$(kubectl get application ${ARGO_APP_NAME} -n argocd -o jsonpath='{.status.sync.revision}' 2>/dev/null || true)

                      echo "Attempt $i/60 -> Sync=${SYNC_STATUS}, Health=${HEALTH_STATUS}, LiveRevision=${LIVE_REVISION}, TargetRevision=${TARGET_REVISION}"

                      if [ "$LIVE_REVISION" = "$TARGET_REVISION" ] && [ "$SYNC_STATUS" = "Synced" ] && [ "$HEALTH_STATUS" = "Healthy" ]; then
                        echo "Argo CD synced expected revision."
                        exit 0
                      fi

                      sleep 5
                    done

                    echo "Argo CD did not sync expected revision in time."
                    kubectl describe application ${ARGO_APP_NAME} -n argocd || true
                    exit 1
                '''
            }
        }

        stage('Wait for Deployment Rollout') {
            steps {
                sh '''
                    set -e
                    export KUBECONFIG=$KUBECONFIG_FILE
                    kubectl rollout status deployment/${DEPLOYMENT_NAME} -n ${K8S_NAMESPACE} --timeout=180s
                '''
            }
        }

        stage('Verify Deployed Image') {
            steps {
                sh '''
                    set -e
                    export KUBECONFIG=$KUBECONFIG_FILE

                    for i in $(seq 1 36); do
                      LIVE_IMAGE=$(kubectl get deployment ${DEPLOYMENT_NAME} -n ${K8S_NAMESPACE} -o jsonpath='{.spec.template.spec.containers[0].image}')
                      echo "Attempt $i/36 -> Live image: $LIVE_IMAGE, Expected: ${REGISTRY_IMAGE}:${IMAGE_TAG}"

                      if [ "$LIVE_IMAGE" = "${REGISTRY_IMAGE}:${IMAGE_TAG}" ]; then
                        echo "Deployment image matches expected image."
                        exit 0
                      fi

                      sleep 5
                    done

                    echo "Deployment image mismatch after waiting!"
                    kubectl get deployment ${DEPLOYMENT_NAME} -n ${K8S_NAMESPACE} -o yaml | grep image: || true
                    exit 1
                '''
            }
        }

        stage('Health Check') {
            steps {
                sh '''
                    set -e
                    sleep 5
                    curl --fail http://${APP_HOST}:${APP_PORT}/health
                    curl --fail http://${APP_HOST}:${APP_PORT}/version
                    curl --fail http://${APP_HOST}:${APP_PORT}/info
                '''
            }
        }
    }

    post {
        success {
            echo "GitOps deployment successful: ${REGISTRY_IMAGE}:${IMAGE_TAG}"
        }
        failure {
            echo "GitOps deployment failed."
            sh '''
                export KUBECONFIG=$KUBECONFIG_FILE
                kubectl get application ${ARGO_APP_NAME} -n argocd -o wide || true
                kubectl describe application ${ARGO_APP_NAME} -n argocd || true
                kubectl get pods -n ${K8S_NAMESPACE} -o wide || true
                kubectl describe deployment ${DEPLOYMENT_NAME} -n ${K8S_NAMESPACE} || true
                POD_NAME=$(kubectl get pods -n ${K8S_NAMESPACE} -l app=devops-platform -o jsonpath='{.items[0].metadata.name}' 2>/dev/null || true)
                if [ -n "$POD_NAME" ]; then
                  kubectl logs -n ${K8S_NAMESPACE} $POD_NAME --tail=100 || true
                fi
            '''
        }
    }
}