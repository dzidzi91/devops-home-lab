pipeline {
    agent any

    environment {
        REGISTRY_IMAGE   = "192.168.56.10:5000/devops-platform-app"
        KUBECONFIG_FILE  = credentials('k8s-homelab-kubeconfig')
        K8S_NAMESPACE    = "devops"
        DEPLOYMENT_NAME  = "devops-platform"
        CONTAINER_NAME   = "devops-platform"
        APP_HOST         = "192.168.56.12"
        APP_PORT         = "30080"
        GIT_BRANCH       = "main"
        MANIFEST_FILE    = "k8s/devops-platform.yaml"
        ARGO_APP_NAME    = "devops-platform"
        IMAGE_TAG        = "build-${BUILD_NUMBER}"
    }

    stages {
        stage('Checkout SCM') {
            steps {
                checkout scm
            }
        }

        stage('Show Build Target') {
            steps {
                echo "Building image: ${REGISTRY_IMAGE}:${IMAGE_TAG}"
                echo "Manifest file: ${MANIFEST_FILE}"
                echo "Argo app: ${ARGO_APP_NAME}"
            }
        }

        stage('Build Docker Image') {
            steps {
                sh '''
                    set -e
                    docker build -t ${REGISTRY_IMAGE}:${IMAGE_TAG} ./app
                '''
            }
        }

        stage('Push Docker Image') {
            steps {
                sh '''
                    set -e
                    docker push ${REGISTRY_IMAGE}:${IMAGE_TAG}
                '''
            }
        }

        stage('Check Kubernetes & Argo Access') {
            steps {
                sh '''
                    set -e
                    export KUBECONFIG=$KUBECONFIG_FILE

                    kubectl get nodes
                    kubectl get application ${ARGO_APP_NAME} -n argocd
                    kubectl get deployment ${DEPLOYMENT_NAME} -n ${K8S_NAMESPACE}
                '''
            }
        }

        stage('Update Manifest') {
            steps {
                sh '''
                    set -e

                    test -f "${MANIFEST_FILE}"

                    sed -i "s|image: .*|image: ${REGISTRY_IMAGE}:${IMAGE_TAG}|g" "${MANIFEST_FILE}"
                    sed -i '/name: APP_VERSION/{n;s|value: ".*"|value: "'"${IMAGE_TAG}"'"|;}' "${MANIFEST_FILE}"

                    echo "Manifest after update:"
                    grep -nE "image:|APP_VERSION|value:" "${MANIFEST_FILE}" || true
                '''
            }
        }

        stage('Commit and Push to Git') {
            steps {
                sh '''
                    set -e

                    git config user.name "Jenkins"
                    git config user.email "jenkins@local"

                    if git diff --quiet -- "${MANIFEST_FILE}"; then
                      echo "No changes detected in manifest."
                      exit 0
                    fi

                    git add "${MANIFEST_FILE}"
                    git commit -m "GitOps deploy ${DEPLOYMENT_NAME}:${IMAGE_TAG}"
                    git push origin HEAD:${GIT_BRANCH}
                '''
            }
        }

        stage('Wait for Argo CD Sync') {
            steps {
                sh '''
                    set -e
                    export KUBECONFIG=$KUBECONFIG_FILE

                    for i in $(seq 1 48); do
                      SYNC_STATUS=$(kubectl get application ${ARGO_APP_NAME} -n argocd -o jsonpath='{.status.sync.status}' 2>/dev/null || true)
                      HEALTH_STATUS=$(kubectl get application ${ARGO_APP_NAME} -n argocd -o jsonpath='{.status.health.status}' 2>/dev/null || true)
                      REVISION=$(kubectl get application ${ARGO_APP_NAME} -n argocd -o jsonpath='{.status.sync.revision}' 2>/dev/null || true)

                      echo "Attempt $i/48 -> Sync=${SYNC_STATUS}, Health=${HEALTH_STATUS}, Revision=${REVISION}"

                      if [ "$SYNC_STATUS" = "Synced" ] && [ "$HEALTH_STATUS" = "Healthy" ]; then
                        echo "Argo CD app is Synced and Healthy."
                        exit 0
                      fi

                      sleep 5
                    done

                    echo "Argo CD did not become Synced/Healthy in time."
                    kubectl describe application ${ARGO_APP_NAME} -n argocd || true
                    exit 1
                '''
            }
        }

        stage('Wait for Deployment Rollout') {
            steps {
                sh '''
                    set -e
                    export KUBECONFIG=$KUBECONFIG_FILE

                    kubectl rollout status deployment/${DEPLOYMENT_NAME} \
                      -n ${K8S_NAMESPACE} \
                      --timeout=180s
                '''
            }
        }

        stage('Health Check') {
            steps {
                sh '''
                    set -e
                    sleep 5
                    curl --fail http://${APP_HOST}:${APP_PORT}/health
                    curl --fail http://${APP_HOST}:${APP_PORT}/version
                    curl --fail http://${APP_HOST}:${APP_PORT}/info
                '''
            }
        }

        stage('Show Logs') {
            steps {
                sh '''
                    export KUBECONFIG=$KUBECONFIG_FILE
                    POD_NAME=$(kubectl get pods -n ${K8S_NAMESPACE} -l app=devops-platform -o jsonpath='{.items[0].metadata.name}')
                    kubectl logs -n ${K8S_NAMESPACE} $POD_NAME --tail=50 || true
                '''
            }
        }
    }

    post {
        success {
            echo "GitOps deployment successful: ${REGISTRY_IMAGE}:${IMAGE_TAG}"
        }
        failure {
            echo "GitOps deployment failed."
            sh '''
                export KUBECONFIG=$KUBECONFIG_FILE
                kubectl get application ${ARGO_APP_NAME} -n argocd -o wide || true
                kubectl describe application ${ARGO_APP_NAME} -n argocd || true
                kubectl get pods -n ${K8S_NAMESPACE} -o wide || true
                kubectl describe deployment ${DEPLOYMENT_NAME} -n ${K8S_NAMESPACE} || true
                POD_NAME=$(kubectl get pods -n ${K8S_NAMESPACE} -l app=devops-platform -o jsonpath='{.items[0].metadata.name}' 2>/dev/null || true)
                if [ -n "$POD_NAME" ]; then
                  kubectl logs -n ${K8S_NAMESPACE} $POD_NAME --tail=100 || true
                fi
            '''
        }
    }
}