pipeline {
    agent any

    parameters {
        string(name: 'IMAGE_TAG', defaultValue: 'ci', description: 'Docker image tag to deploy, e.g. build-6')
    }

    environment {
        REGISTRY_IMAGE = "192.168.56.10:5000/devops-platform-app"
        KUBECONFIG_FILE = credentials('k8s-homelab-kubeconfig')
        K8S_NAMESPACE = "default"
        DEPLOYMENT_NAME = "devops-platform"
        CONTAINER_NAME = "devops-platform"
        APP_HOST = "192.168.56.12"
        APP_PORT = "30080"
        DEPLOY_TAG = "${params.IMAGE_TAG}"
    }

    stages {
        stage('Show Deploy Target') {
            steps {
                echo "Deploying image: ${REGISTRY_IMAGE}:${DEPLOY_TAG}"
            }
        }

        stage('Check Kubernetes Access') {
            steps {
                sh '''
                    export KUBECONFIG=$KUBECONFIG_FILE
                    kubectl get nodes
                    kubectl get deployment ${DEPLOYMENT_NAME} -n ${K8S_NAMESPACE}
                '''
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                sh '''
                    export KUBECONFIG=$KUBECONFIG_FILE

                    kubectl set image deployment/${DEPLOYMENT_NAME} \
                      ${CONTAINER_NAME}=${REGISTRY_IMAGE}:$DEPLOY_TAG \
                      -n ${K8S_NAMESPACE}

                    kubectl set env deployment/${DEPLOYMENT_NAME} \
                      APP_VERSION=$DEPLOY_TAG \
                      -n ${K8S_NAMESPACE}

                    kubectl rollout status deployment/${DEPLOYMENT_NAME} \
                      -n ${K8S_NAMESPACE} \
                      --timeout=180s
                '''
            }
        }

        stage('Check Deployment') {
            steps {
                sh '''
                    export KUBECONFIG=$KUBECONFIG_FILE
                    kubectl get pods -n ${K8S_NAMESPACE} -o wide
                    kubectl describe deployment ${DEPLOYMENT_NAME} -n ${K8S_NAMESPACE}
                '''
            }
        }

        stage('Health Check') {
            steps {
                sh '''
                    sleep 5
                    curl --fail http://${APP_HOST}:${APP_PORT}/health
                    curl --fail http://${APP_HOST}:${APP_PORT}/version
                    curl --fail http://${APP_HOST}:${APP_PORT}/info
                '''
            }
        }

        stage('Show Logs') {
            steps {
                sh '''
                    export KUBECONFIG=$KUBECONFIG_FILE
                    POD_NAME=$(kubectl get pods -n ${K8S_NAMESPACE} -l app=devops-platform -o jsonpath='{.items[0].metadata.name}')
                    kubectl logs -n ${K8S_NAMESPACE} $POD_NAME --tail=50 || true
                '''
            }
        }
    }

    post {
        success {
            echo "Kubernetes deployment successful: ${REGISTRY_IMAGE}:${DEPLOY_TAG}"
        }
        failure {
            echo "Kubernetes deployment failed."
            sh '''
                export KUBECONFIG=$KUBECONFIG_FILE
                kubectl get pods -n ${K8S_NAMESPACE} -o wide || true
                kubectl describe deployment ${DEPLOYMENT_NAME} -n ${K8S_NAMESPACE} || true
                POD_NAME=$(kubectl get pods -n ${K8S_NAMESPACE} -l app=devops-platform -o jsonpath='{.items[0].metadata.name}' 2>/dev/null || true)
                if [ -n "$POD_NAME" ]; then
                  kubectl logs -n ${K8S_NAMESPACE} $POD_NAME --tail=100 || true
                fi
            '''
        }
    }
}