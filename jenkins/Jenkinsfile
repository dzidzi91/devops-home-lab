pipeline {
    agent any

    parameters {
        string(name: 'IMAGE_TAG', defaultValue: 'ci', description: 'Docker image tag to deploy, e.g. build-6')
    }

    environment {
        REGISTRY_IMAGE = "localhost:5000/devops-platform-app"
        APP_CONTAINER = "devops-platform-app"
        APP_PORT = "8000"
    }

    stages {
        stage('Show Deploy Target') {
            steps {
                echo "Deploying image: ${REGISTRY_IMAGE}:${params.IMAGE_TAG}"
            }
        }

        stage('Pull Image') {
            steps {
                sh "docker pull ${REGISTRY_IMAGE}:${params.IMAGE_TAG}"
            }
        }

        stage('Stop Old Container') {
            steps {
                sh '''
                    docker stop ${APP_CONTAINER} || true
                    docker rm ${APP_CONTAINER} || true
                '''
            }
        }

        stage('Run New Container') {
            steps {
                sh """
                    docker run -d \
                      --name ${APP_CONTAINER} \
                      -p ${APP_PORT}:8000 \
                      ${REGISTRY_IMAGE}:${params.IMAGE_TAG}
                """
            }
        }

        stage('Check Container Running') {
            steps {
                sh '''
                    sleep 5
                    docker ps --filter "name=${APP_CONTAINER}" --filter "status=running"
                    docker inspect -f '{{.State.Running}}' ${APP_CONTAINER} | grep true
                '''
            }
        }

        stage('Show Logs') {
            steps {
                sh 'docker logs --tail 50 ${APP_CONTAINER} || true'
            }
        }
    }

    post {
        success {
            echo "Deployment successful: ${REGISTRY_IMAGE}:${params.IMAGE_TAG}"
        }
        failure {
            echo "Deployment failed."
            sh '''
                docker ps -a || true
                docker logs --tail 100 ${APP_CONTAINER} || true
            '''
        }
    }
}