pipeline {
    agent any

    environment {
        IMAGE_NAME = "192.168.56.10:5000/devops-platform-app"
        IMAGE_TAG = "build-${BUILD_NUMBER}"
        KUBECONFIG_FILE = credentials('k8s-homelab-kubeconfig')
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build Docker Image') {
            steps {
                sh '''
                    cd /workspace/devops-lab
                    docker build -t ${IMAGE_NAME}:${IMAGE_TAG} -f docker/Dockerfile .
                '''
            }
        }

        stage('Push Docker Image') {
            steps {
                sh '''
                    docker push ${IMAGE_NAME}:${IMAGE_TAG}
                '''
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                sh '''
                    export KUBECONFIG=$KUBECONFIG_FILE

                    kubectl set image deployment/devops-platform \
                      devops-platform=${IMAGE_NAME}:${IMAGE_TAG} \
                      -n default

                    kubectl set env deployment/devops-platform \
                      APP_VERSION=${IMAGE_TAG} \
                      -n default

                    kubectl rollout status deployment/devops-platform -n default --timeout=180s
                    kubectl get pods -n default -o wide
                '''
            }
        }
    }
}