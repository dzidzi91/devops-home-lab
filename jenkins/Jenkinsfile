pipeline {
    agent any

    parameters {
        string(name: 'IMAGE_TAG', defaultValue: 'ci', description: 'Docker image tag to deploy, e.g. build-1')
    }

    environment {
        REGISTRY_IMAGE = "localhost:5000/devops-platform-app"
        IMAGE = "${REGISTRY_IMAGE}:${params.IMAGE_TAG}"
        APP_CONTAINER = "devops-platform-app"
        APP_PORT = "8000"
    }

    stages {
        stage('Pull Image') {
            steps {
                echo "Pulling image ${IMAGE}..."
                sh "docker pull ${IMAGE}"
            }
        }

        stage('Stop Old Container') {
            steps {
                echo "Stopping old container if it exists..."
                sh '''
                    docker stop ${APP_CONTAINER} || true
                    docker rm ${APP_CONTAINER} || true
                '''
            }
        }

        stage('Run New Container') {
            steps {
                echo "Starting new container from ${IMAGE}..."
                sh '''
                    docker run -d \
                      --name ${APP_CONTAINER} \
                      -p ${APP_PORT}:8000 \
                      ${IMAGE}
                '''
            }
        }

        stage('Health Check') {
            steps {
                echo 'Waiting for application to start...'
                sh '''
                    for i in $(seq 1 15); do
                      curl -fsS http://localhost:${APP_PORT} && exit 0
                      sleep 2
                    done
                    echo "Application health check failed."
                    exit 1
                '''
            }
        }
    }

    post {
        success {
            echo "Deployment successful: ${IMAGE}"
        }
        failure {
            echo "Deployment failed."
            sh 'docker ps -a || true'
        }
    }
}